{
  "name": "bluearchive-cafe-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "optimize:hero": "node scripts/optimize-hero-images.mjs",
    "prune:hero": "node scripts/prune-dist-hero-originals.mjs",
    "build": "npm run optimize:hero && vue-tsc -b && vite build && npm run prune:hero",
    "build:pages": "npm run build && node scripts/create-pages-fallback.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "markdown-it": "^14.1.1",
    "medium-zoom": "^1.1.0",
    "vite-plugin-vuetify": "^2.0.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.7",
    "vuetify": "^3.7.6"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "sass-embedded": "^1.100.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vue-tsc": "^2.1.10"
  }
}
